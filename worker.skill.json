{
  "schema_version": "1",
  "skill_id": "claude-worker",
  "name": "Claude Worker",
  "kind": "worker",
  "version": "0.3.0",
  "status": "active",
  "entrypoint": "python -m claude_worker",
  "default_execution_mode": "one_shot",
  "supported_execution_modes": ["one_shot", "detached", "interactive"],
  "invocation_patterns": {
    "task_mode": {
      "description": "Single task, single result. CC exits after completion.",
      "modes": ["one_shot", "detached"],
      "cli": "start --execution-mode one_shot|detached → wait → fetch"
    },
    "session_chain_mode": {
      "description": "Multi-turn via separate CC invocations linked by --resume. Crash-resilient.",
      "cli": "start → wait → fetch → continue --run-id <id> --prompt '...'"
    },
    "live_session_mode": {
      "description": "CC process stays alive, accepts multiple prompts via bidirectional streaming.",
      "cli": "session-start → session-send/capture × N → session-stop",
      "class": "LongRunSession"
    }
  },
  "model_switching": {
    "default_model": "qwen3.6-plus",
    "supported_models": ["qwen3.6-plus", "qwen3-coder-plus", "qwen3.5-plus", "qwen3-coder-next", "glm-5.1", "glm-5", "glm-4.7", "glm-4.5-air", "MiniMax-M2.5", "kimi-k2.5"],
    "supported_providers": ["bailian-cp", "zhipu-cp", "z-ai", "anthropic", "deepseek"],
    "supports_model_override": true,
    "supports_provider_override": true,
    "provider_policy": "external_harness_controlled",
    "reasoning_mode_default": "high",
    "reasoning_control": {
      "flag": "--effort",
      "values": ["low", "medium", "high", "max"],
      "mechanism": "CC maps --effort to thinking.budget_tokens in Anthropic API",
      "verified_providers": {
        "z-ai": { "thinking_supported": true, "behavior": "budget-controlled, no thinking without param" },
        "qwen-bailian-coding": { "thinking_supported": true, "behavior": "default-on, budget controls depth" }
      }
    }
  },
  "cc_native_capabilities": {
    "max_turns": true,
    "allowed_tools": true,
    "resume_session": true,
    "continue_session": true,
    "fork_session": true,
    "bare_mode": true,
    "output_format": ["json", "stream-json", "text"],
    "input_files": true,
    "bidirectional_streaming": true,
    "effort_control": true
  },
  "artifact_contract": [
    "meta.json",
    "events.ndjson",
    "stdout.txt",
    "stderr.txt",
    "exitcode.txt",
    "final.json",
    "harness_result.json",
    "summary.md",
    "patch.diff",
    "supervisor.json",
    "prompt.txt"
  ],
  "result_protocol": {
    "summary": true,
    "files_changed": true,
    "why_this_solution": true,
    "validation_run": true,
    "known_risks": true,
    "recommendation": true,
    "execution_mode": true,
    "prompt_delivery": true,
    "lifecycle": true,
    "model_provenance": true
  },
  "trust_boundary": {
    "role": "delegated_worker",
    "cannot": [
      "change priorities",
      "change acceptance criteria",
      "change runtime truth",
      "change AI evolution direction"
    ]
  },
  "validation_hooks": [
    "python -m pytest tests/test_claude_worker.py -v"
  ],
  "stop_conditions": [
    "controller architecture changes required",
    "generic multi-agent framework rewrite",
    "sandbox enforcement claims exceed evidence",
    "durable artifact claims are not supported by files on disk"
  ]
}
